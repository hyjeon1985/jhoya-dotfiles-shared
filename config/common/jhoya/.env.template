# Non-secret defaults for jhoya-dotfiles.
# Copy to ~/.config/jhoya/.env and adjust as needed.

# Git identity (applied by scripts/install.sh when both values are set)
export GIT_NAME=""
export GIT_EMAIL=""
export GIT_AUTO_CONFIG="1"

# Do not export OPENAI_BASE_URL / OPENAI_API_KEY globally.
# Keep provider-specific endpoints/keys in per-tool local configs only.
export JHOYA_FONT_MONO="D2CodingLigature Nerd Font"
export JHOYA_FONT_UI="Pretendard"
export JHOYA_FONT_KO="Pretendard"
export JHOYA_WEZTERM_FONT_SIZE="14.0"
# Optional macOS-only override when you want a different WezTerm size on macOS.
# export JHOYA_WEZTERM_FONT_SIZE_MACOS="16.0"

# Optional: add locale/editor preferences here.
# export EDITOR="nvim"
